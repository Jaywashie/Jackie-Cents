<!DOCTYPE html>
<html lang="en" style="scrollbar-gutter: stable;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · JackieCents">
      <%= assigns[:page_title] || "Insurance" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
      * { font-family: 'Plus Jakarta Sans', sans-serif; }
      .font-display { font-family: 'DM Serif Display', serif; }
      .nav-glass {
        background: rgba(20, 83, 45, 0.97);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      .hero-gradient {
        background: linear-gradient(135deg, #14532d 0%, #166534 40%, #15803d 100%);
      }
      .card-hover {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.12);
      }
      .btn-primary {
        background: linear-gradient(135deg, #16a34a, #15803d);
        transition: all 0.2s ease;
      }
      .btn-primary:hover {
        background: linear-gradient(135deg, #15803d, #166534);
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(22, 163, 74, 0.4);
      }
      .badge-active {
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
      }
      .badge-expired {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #991b1b;
      }
    </style>
  </head>

  <!-- NAVBAR -->
  <nav class="nav-glass sticky top-0 z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex justify-between items-center h-16">

        <!-- Logo -->
        <.link navigate="/" class="flex items-center space-x-2 group">
          <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center shadow">
            <svg class="w-5 h-5 text-green-700" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-white tracking-tight">
            Jackie<span class="text-green-300">Cents</span>
          </span>
        </.link>

        <!-- Nav Links -->
        <div class="hidden md:flex items-center space-x-1">
          <.link navigate="/" class="text-green-100 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">Home</.link>
          <.link navigate="/medical" class="text-green-100 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">Medical</.link>
          <.link navigate="/life" class="text-green-100 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">Life</.link>
          <.link navigate="/motor" class="text-green-100 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">Motor</.link>
          <.link navigate="/pension" class="text-green-100 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">Pension</.link>
          <%= if @current_user do %>
       <.link navigate="/my-quotes" class="text-green-100 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">
       My Quotes
       </.link>
        <% end %>
        </div>

        <!-- Auth -->
        <div class="flex items-center space-x-3">
          <%= if @current_user do %>
            <span class="hidden md:block text-green-200 text-sm">
              👋 <%= @current_user.email %>
            </span>
            <.link href={~p"/users/settings"} class="text-green-100 hover:text-white text-sm font-medium transition-all">
              Settings
            </.link>
            <.link
              href={~p"/users/log_out"}
              method="delete"
              class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg text-sm font-semibold border border-white/20 transition-all"
            >
              Log out
            </.link>
          <% else %>
            <.link
              href={~p"/users/register"}
              class="text-green-100 hover:text-white text-sm font-medium transition-all"
            >
              Register
            </.link>
            <.link
              href={~p"/users/log_in"}
              class="bg-white text-green-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-green-50 transition-all shadow"
            >
              Log in
            </.link>
          <% end %>
        </div>

      </div>
    </div>
  </nav>

  <body class="bg-gray-50 antialiased min-h-screen flex flex-col">
    <%= @inner_content %>
  </body>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-300 mt-auto">
    <div class="max-w-7xl mx-auto px-6 py-14 grid md:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-white font-bold text-lg">JackieCents</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Plan today for a secure tomorrow. Trusted insurance solutions for every stage of life.
        </p>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Products</h3>
        <ul class="space-y-2 text-sm">
          <li><.link navigate="/medical" class="hover:text-green-400 transition-colors">Medical Cover</.link></li>
          <li><.link navigate="/life" class="hover:text-green-400 transition-colors">Life Insurance</.link></li>
          <li><.link navigate="/motor" class="hover:text-green-400 transition-colors">Motor Cover</.link></li>
          <li><.link navigate="/pension" class="hover:text-green-400 transition-colors">Pension Plan</.link></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Company</h3>
        <ul class="space-y-2 text-sm">
          <li><.link navigate="/" class="hover:text-green-400 transition-colors">Home</.link></li>
          <li><.link navigate="/admin" class="hover:text-green-400 transition-colors">Admin</.link></li>
        </ul>
      </div>

      <!-- Contact & Social -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact</h3>
        <div class="space-y-2 text-sm">
          <p class="flex items-center gap-2">📍 Nairobi, Kenya</p>
          <p class="flex items-center gap-2">✉️ Njerujackline78@gmail.com</p>
          <p class="flex items-center gap-2">📞 +254 721 343 980</p>
        </div>

        <!-- Social Icons -->
        <div class="flex items-center space-x-3 mt-5">
          <a href="https://instagram.com/jackiejosh1" target="_blank" class="w-9 h-9 bg-gray-800 hover:bg-pink-600 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm8.5 1.5h-8.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5z"/><path d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 1.5a3.5 3.5 0 1 1 0 7 3.5 3.5 0 0 1 0-7z"/><circle cx="17.5" cy="6.5" r="1"/>
            </svg>
          </a>
          <a href="https://wa.me/254721343980" target="_blank" class="w-9 h-9 bg-gray-800 hover:bg-green-600 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.04 2C6.58 2 2.14 6.44 2.14 11.9c0 2.11.55 4.16 1.6 5.97L2 22l4.27-1.72a9.82 9.82 0 0 0 5.77 1.84h.01c5.46 0 9.9-4.44 9.9-9.9S17.5 2 12.04 2z"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@jackiecent" target="_blank" class="w-9 h-9 bg-gray-800 hover:bg-gray-600 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.6 2h2.2a5.4 5.4 0 0 0 3.7 3.7v2.2a7.6 7.6 0 0 1-3.7-1v7.4a5.6 5.6 0 1 1-5.6-5.6c.4 0 .8 0 1.2.1v2.3a3.4 3.4 0 1 0 2.2 3.2V2z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@JackieCents" target="_blank" class="w-9 h-9 bg-gray-800 hover:bg-red-600 rounded-lg flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.7 31.7 0 0 0 0 12a31.7 31.7 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.7 31.7 0 0 0 24 12a31.7 31.7 0 0 0-.5-5.8zM9.8 15.5v-7l6.2 3.5-6.2 3.5z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <div class="border-t border-gray-800 py-5 text-center text-sm text-gray-500">
      © 2026 JackieCents Insurance. All rights reserved. · Built with ❤️ in Nairobi
    </div>
  </footer>

</html>
