<!DOCTYPE html>
<html lang="en" style="scrollbar-gutter: stable;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Phoenix Framework">
      <%= assigns[:page_title] || "Insurance" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>

  </head>
 
 <nav class="bg-green-700 shadow-md">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-center h-14">

      <!-- Logo -->
      <div class="flex items-center space-x-2">
        <h1 class="text-2xl font-bold text-white tracking-wide">
          Jackie<span class="text-green-200">Cents</span>
        </h1>
      </div>

      <!-- Links -->
      <div class="flex items-center space-x-6">

        <.link
          navigate="/"
          class="text-white font-medium hover:text-green-200 transition"
        >
          Home
        </.link>

        <.link
          href={~p"/users/settings"}
          class="text-white font-medium hover:text-green-200 transition"
        >
          Settings
        </.link>

        <%= if @current_user do %>
        <h2 class="text-white font-bold">
          Welcome, <%= @current_user.email %>!
        </h2>
          <.link
            href={~p"/users/log_out"}
            method="delete"
            class="bg-white text-green-700 px-4 py-2 rounded-lg font-semibold hover:bg-green-100 transition"
          >
            Log out
          </.link>

        <% else %>
          <.link
            href={~p"/users/register"}
            class="bg-white text-green-700 px-4 py-2 rounded-lg font-semibold hover:bg-green-100 transition"
          >
            Register
          </.link>

          <.link
            href={~p"/users/log_in"}
            class="bg-white text-green-700 px-4 py-2 rounded-lg font-semibold hover:bg-green-100 transition"
          >
            Log in
          </.link>
        <% end %>

      </div>
    </div>
  </div>
</nav>

  <body class="bg-white antialiased">
    
    <%= @inner_content %>
    
  </body>

<footer class="bg-green-700 text-white mt-auto">
  <div class="max-w-7xl mx-auto px-6 py-10 grid md:grid-cols-3 gap-8">

    <!-- Brand -->
    <div>
     <h2 class="text-xl font-bold">JACKIE CENTS</h2>
      <p class="text-green-200 mt-2">
        Plan today for a secure tommorrow
      </p>
    </div>

    <!-- Links -->
    <div>
      <h3 class="font-semibold mb-3">Quick Links</h3>
      <ul class="space-y-2 text-green-200">
        <li><.link navigate={~p"/"} class="hover:text-white">Home</.link></li>
        <li><.link navigate={~p"/medical"} class="hover:text-white">Medical</.link></li>
        <li><.link navigate={~p"/life"} class="hover:text-white">Life</.link></li>
        <li><.link navigate={~p"/motor"} class="hover:text-white">Motor</.link></li>
        <li><.link navigate={~p"/pension"} class="hover:text-white">Pension</.link></li>

      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="font-semibold mb-3">Contact</h3>
      <p class="text-green-300">Nairobi, Kenya</p>
      <p class="text-green-300">Njerujackline78@gmail.com</p>
      <p class="text-green-300">+254 721343980</p>
    </div>

<div class="flex items-center space-x-4">
  <!-- Instagram -->
  <a
    href="https://instagram.com/jackiejosh1"
    target="_blank"
    rel="noopener noreferrer"
    class="text-white-500 hover:text-pink-600 transition"
    aria-label="Instagram"
  >
    <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
      <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm8.5 1.5h-8.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5z"/>
      <path d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 1.5a3.5 3.5 0 1 1 0 7 3.5 3.5 0 0 1 0-7z"/>
      <circle cx="17.5" cy="6.5" r="1"/>
    </svg>
  </a>

  <!-- WhatsApp -->
  <a
    href="https://wa.me/254721343980"
    target="_blank"
    rel="noopener noreferrer"
    class="text-white hover:text-white-600 transition"
    aria-label="WhatsApp"
  >
    <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12.04 2C6.58 2 2.14 6.44 2.14 11.9c0 2.11.55 4.16 1.6 5.97L2 22l4.27-1.72a9.82 9.82 0 0 0 5.77 1.84h.01c5.46 0 9.9-4.44 9.9-9.9S17.5 2 12.04 2z"/>
    </svg>
  </a>

  <!-- TikTok -->
  <a
    href="https://www.tiktok.com/@jackiecent"
    target="_blank"
    rel="noopener noreferrer"
    class="text-white hover:text-white transition"
    aria-label="TikTok"
  >
    <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12.6 2h2.2a5.4 5.4 0 0 0 3.7 3.7v2.2a7.6 7.6 0 0 1-3.7-1v7.4a5.6 5.6 0 1 1-5.6-5.6c.4 0 .8 0 1.2.1v2.3a3.4 3.4 0 1 0 2.2 3.2V2z"/>
    </svg>
  </a>

 <a
  href="https://www.youtube.com/@JackieCents"
  target="_blank"
  rel="noopener noreferrer"
  class="text-white hover:text-red-600 transition"
  aria-label="YouTube"
>
  <svg class="w-9 h-9" viewBox="0 0 24 24" fill="currentColor">
    <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.7 31.7 0 0 0 0 12a31.7 31.7 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.7 31.7 0 0 0 24 12a31.7 31.7 0 0 0-.5-5.8zM9.8 15.5v-7l6.2 3.5-6.2 3.5z"/>
  </svg>
</a>

</div>

  </div>

  <div class="border-t border-white-700 text-center py-4 text-white-400 text-sm">
    © 2026 Jackie Cents. All rights reserved.
  </div>
</footer>


</html>
